# ────────────────────────────────────────────────────────────────────
# 청암홈윈도우 홈페이지 — 로컬 환경변수 템플릿
# 사용법:
#   1) cp .env.local.example .env.local
#   2) 아래 값들을 실제 값으로 채우기
#   3) npm run dev:cf 로 wrangler + Vite 통합 실행
# ────────────────────────────────────────────────────────────────────

# ── Supabase (AS 접수 시스템) ─────────────────────────────────────
# Supabase Dashboard > Project Settings > API 에서 확인

# 서버 전용 (Cloudflare Functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# 브라우저 노출 (Vite 빌드타임에 클라이언트 번들에 포함)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── ERP 연동 (cahwindow-Quote) ────────────────────────────────────
# ERP 측에 등록된 동일 시크릿. 32자 이상 랜덤 문자열.
EXTERNAL_LEAD_API_KEY=replace-with-32-char-random-secret

# ERP 엔드포인트 base URL
# - 운영: https://cahwindow-quote.vercel.app
# - 로컬 검증: http://localhost:3000 (cahwindow-Quote를 별도 터미널에서 pnpm dev)
# - Vercel preview: https://cahwindow-quote-git-xxx.vercel.app
ERP_API_BASE=https://cahwindow-quote.vercel.app

# AS 전용 API 키 (필요 시)
ERP_AS_API_KEY=

# ERP 측 호환을 위해 functions/api/as/* 에서 사용하는 키 이름
ERP_BASE_URL=https://cahwindow-quote.vercel.app

# ── 후기 시스템 Firebase 직접 연동 (cahwindow-quote 프로젝트) ─────
# 사용자 결정 (2026-05-18): ERP 백엔드 우회. 홈페이지 Cloudflare Functions 가
# ERP 와 같은 Firebase 프로젝트에 시스템 계정으로 signIn → Firestore/Storage 직접.
# ERP 의 NEXT_PUBLIC_FIREBASE_* 와 동일 값.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=cahwindow-quote.firebaseapp.com
FIREBASE_PROJECT_ID=cahwindow-quote
FIREBASE_STORAGE_BUCKET=cahwindow-quote.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# 홈페이지 후기 시스템 전용 시스템 계정 (부사장님이 Firebase Auth 에 신규 발급)
# users/{uid}.role='admin' 으로 승격 필요. 미지정 시 익명 로그인 폴백.
# 익명 로그인은 inboundCustomers/reviews 등 admin 권한 컬렉션 접근 불가.
SYSTEM_AUTH_EMAIL=
SYSTEM_AUTH_PASSWORD=

# 자체 JWT secret — customer-lookup → submit 토큰 서명 (30분 TTL, HS256).
# 32자 이상 랜덤 문자열. openssl rand -hex 32 등으로 생성.
REVIEW_JWT_SECRET=

# ── 후기 시스템 운영 토글 (docs/REVIEW_GO_LIVE.md) ────────────────
# 1 = ON  → GNB "시공후기" 메뉴 + 메인 ReviewSection 신디자인(featured 카드)
#           + /review 리스트/상세 페이지 노출
# 빈 값/0 = OFF → GNB 숨김 + 메인 ReviewSection 구디자인(채팅버블 5줄)
#                 + /review 진입 시 / 로 리다이렉트
#                 단 EventSection 골드 CTA → /review/new 작성 진입은 항상 살아있음
VITE_REVIEW_SECTION_LIVE=

# 개발 편의용 mock 분기. 1로 설정 시 Firebase 호출 없이 가상 응답으로 UI 동작 확인.
#   - phoneLast4=0000 → matched: 'none'
#   - phoneLast4=9999 → matched: 'multiple'
#   - phoneLast4=1111 → matched: 'already_reviewed'
#   - 그 외          → matched: 'one' (mock-token 발급)
VITE_REVIEW_MOCK=
