# ────────────────────────────────────────────────────────────────────
# 청암홈윈도우 홈페이지 — 로컬 환경변수 템플릿
# 사용법:
#   1) cp .env.local.example .env.local
#   2) 아래 값들을 실제 값으로 채우기
#   3) npm run dev:cf 로 wrangler + Vite 통합 실행
# ────────────────────────────────────────────────────────────────────

# ── Supabase (AS 접수 시스템) ─────────────────────────────────────
# Supabase Dashboard > Project Settings > API 에서 확인

# 서버 전용 (Cloudflare Functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# 브라우저 노출 (Vite 빌드타임에 클라이언트 번들에 포함)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── ERP 연동 (cahwindow-Quote) ────────────────────────────────────
# ERP 측에 등록된 동일 시크릿. 32자 이상 랜덤 문자열.
EXTERNAL_LEAD_API_KEY=replace-with-32-char-random-secret

# ERP 엔드포인트 base URL
# - 운영: https://cahwindow-quote.vercel.app
# - 로컬 검증: http://localhost:3000 (cahwindow-Quote를 별도 터미널에서 pnpm dev)
# - Vercel preview: https://cahwindow-quote-git-xxx.vercel.app
ERP_API_BASE=https://cahwindow-quote.vercel.app
